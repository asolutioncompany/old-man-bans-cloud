#!/bin/bash
# perm-list - Show all permanently banned entries

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0"
fi

if ! ipset list badnets_perm &>/dev/null; then
    echo "No permanent bans (set badnets_perm does not exist)."
    exit 0
fi

echo "Permanent bans:"
ipset list badnets_perm | sed -n '/^Members:/,$ p' | tail -n +2 | awk '
{
    entry=$0
    # Normalize singleton IPv4 entries to /32 for portable backups.
    if (entry !~ /\// && entry ~ /^([0-9]{1,3}\.){3}[0-9]{1,3}$/) {
        entry = entry "/32"
    }

    is_subnet = (entry ~ /\/24$/) ? 0 : 1
    split(entry, parts, "/")
    split(parts[1], oct, ".")
    ipkey = sprintf("%03d.%03d.%03d.%03d", oct[1], oct[2], oct[3], oct[4])
    print is_subnet "|" ipkey "|" entry
}' | sort -t'|' -k1,1n -k2,2 | awk -F'|' '
{
    print $3
    if ($3 ~ /\/24$/) subnet_count++
    else if ($3 ~ /\/32$/) singleton_count++
}
END {
    printf("\nTotals:\n")
    printf("Subnet bans (/24): %d\n", subnet_count + 0)
    printf("Singleton bans (/32): %d\n", singleton_count + 0)
}'
