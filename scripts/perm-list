#!/bin/bash
# perm-list - Show all permanently banned entries

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0"
fi

if ! ipset list badnets_perm &>/dev/null; then
    echo "No permanent bans (set badnets_perm does not exist)."
    exit 0
fi

echo "Permanent bans:"
ipset list badnets_perm | sed -n '/^Members:/,$ p' | tail -n +2