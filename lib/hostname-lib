#!/bin/bash
# hostname-lib - persistent hostname lookup cache helpers.

declare -gA HOSTNAME_CACHE

hostname_cache_load() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    while IFS=$'\t' read -r ip hostname; do
        [[ -z "$ip" ]] && continue
        HOSTNAME_CACHE["$ip"]="$hostname"
    done < "$file"
}

hostname_cache_save() {
    local file="$1"
    local tmp
    tmp="$(mktemp)"
    for ip in "${!HOSTNAME_CACHE[@]}"; do
        printf '%s\t%s\n' "$ip" "${HOSTNAME_CACHE[$ip]}" >> "$tmp"
    done
    mv "$tmp" "$file"
}

hostname_lookup_raw() {
    local ip="$1"
    local timeout_seconds="$2"
    local host_out

    if host_out="$(timeout "${timeout_seconds}s" host "$ip" 2>/dev/null)"; then
        if [[ "$host_out" =~ pointer[[:space:]]+([^[:space:]]+)\.?$ ]]; then
            echo "${BASH_REMATCH[1]}"
            return 0
        fi
    else
        local rc=$?
        if [[ $rc -eq 124 ]]; then
            echo "-TIMEOUT-"
            return 0
        fi
    fi

    if host_out="$(timeout "${timeout_seconds}s" dig +short -x "$ip" 2>/dev/null)"; then
        local ptr
        ptr="$(echo "$host_out" | sed '/^[[:space:]]*$/d' | sed -n '1p' | sed 's/\.$//')"
        if [[ -n "$ptr" ]]; then
            echo "$ptr"
            return 0
        fi
    else
        local rc=$?
        if [[ $rc -eq 124 ]]; then
            echo "-TIMEOUT-"
            return 0
        fi
    fi

    echo "-"
}

hostname_cache_get() {
    local ip="$1"
    local timeout_seconds="$2"
    if [[ -n "${HOSTNAME_CACHE[$ip]+x}" ]]; then
        echo "${HOSTNAME_CACHE[$ip]}"
        return 0
    fi
    HOSTNAME_CACHE["$ip"]="$(hostname_lookup_raw "$ip" "$timeout_seconds")"
    echo "${HOSTNAME_CACHE[$ip]}"
}
