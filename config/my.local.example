# Example local overrides.
# Copy this file to any name ending in .local (for example: my.local).
# Local files are loaded after old-man-bans-cloud.conf, so values here override defaults.

# Example: custom nginx log location(s).
# Multiple directories can be separated by space, tab, or newline.
# LOG_DIR=/var/www/my-site-logs
# LOG_DIR=/var/www/site-a-logs /var/www/site-b-logs
# ACCESS_LOG_BASENAME=access.log

# Example: tune subnet promotion threshold.
# SUBNET_THRESHOLD=15

# Example: disable banning but keep logging.
# HOST_SCAN_BAN=off
# AGENT_SCAN_BAN=off
# SITEMAP_SCAN_BAN=off

# Example: complete override of bad hostname tokens.
# This replaces all defaults (does not append).
# BAD_HOSTNAMES=example.com|example.net

# Example: complete override of known-good agents.
# GOOD_AGENTS=googlebot|bingbot

# Example: complete override of sitemap path tokens.
# SITEMAP_TOKENS=sitemap|robots.txt
