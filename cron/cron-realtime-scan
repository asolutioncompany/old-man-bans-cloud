#!/bin/bash
# cron-realtime-scan - Realtime scan of current nginx access log interval.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/common-lib"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/agent-lib"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/hostname-lib"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/urlpattern-lib"

LOG_DIR_DEFAULT="/var/log/nginx"
ACCESS_LOG_BASENAME_DEFAULT="access.log"
DNS_TIMEOUT_SECONDS_DEFAULT=3
HOST_SCAN_LOG_DEFAULT="on"
HOST_SCAN_BAN_DEFAULT="on"
AGENT_SCAN_LOG_DEFAULT="on"
AGENT_SCAN_BAN_DEFAULT="on"
URLPATTERN_SCAN_LOG_DEFAULT="on"
URLPATTERN_SCAN_BAN_DEFAULT="on"

LOGS_DIR="$ROOT_DIR/logs"
ensure_logs_dir "$LOGS_DIR"

STATE_FILE="$LOGS_DIR/realtime-scan.state"
LOCK_FILE="$LOGS_DIR/realtime-scan.lock"
HOSTNAME_CACHE_FILE="$LOGS_DIR/hostname-cache.tsv"
HOST_BAN_LOG="$LOGS_DIR/host-ban-log"
AGENT_BAN_LOG="$LOGS_DIR/agent-ban-log"
AGENT_UNIQUE_LOG="$LOGS_DIR/unique-agent-log"
URLPATTERN_BAN_LOG="$LOGS_DIR/urlpattern-ban-log"

load_config_layers "$ROOT_DIR/config"

LOG_DIR="${LOG_DIR:-$LOG_DIR_DEFAULT}"
ACCESS_LOG_BASENAME="${ACCESS_LOG_BASENAME:-$ACCESS_LOG_BASENAME_DEFAULT}"
DNS_TIMEOUT_SECONDS="${DNS_TIMEOUT_SECONDS:-$DNS_TIMEOUT_SECONDS_DEFAULT}"
HOST_SCAN_LOG="${HOST_SCAN_LOG:-$HOST_SCAN_LOG_DEFAULT}"
HOST_SCAN_BAN="${HOST_SCAN_BAN:-$HOST_SCAN_BAN_DEFAULT}"
AGENT_SCAN_LOG="${AGENT_SCAN_LOG:-$AGENT_SCAN_LOG_DEFAULT}"
AGENT_SCAN_BAN="${AGENT_SCAN_BAN:-$AGENT_SCAN_BAN_DEFAULT}"
URLPATTERN_SCAN_LOG="${URLPATTERN_SCAN_LOG:-$URLPATTERN_SCAN_LOG_DEFAULT}"
URLPATTERN_SCAN_BAN="${URLPATTERN_SCAN_BAN:-$URLPATTERN_SCAN_BAN_DEFAULT}"

validate_on_off "HOST_SCAN_LOG" "$HOST_SCAN_LOG"
validate_on_off "HOST_SCAN_BAN" "$HOST_SCAN_BAN"
validate_on_off "AGENT_SCAN_LOG" "$AGENT_SCAN_LOG"
validate_on_off "AGENT_SCAN_BAN" "$AGENT_SCAN_BAN"
validate_on_off "URLPATTERN_SCAN_LOG" "$URLPATTERN_SCAN_LOG"
validate_on_off "URLPATTERN_SCAN_BAN" "$URLPATTERN_SCAN_BAN"

if [[ "$HOST_SCAN_LOG" == "off" && "$HOST_SCAN_BAN" == "off" && \
      "$AGENT_SCAN_LOG" == "off" && "$AGENT_SCAN_BAN" == "off" && \
      "$URLPATTERN_SCAN_LOG" == "off" && "$URLPATTERN_SCAN_BAN" == "off" ]]; then
    echo "All realtime LOG/BAN settings are off; exiting."
    exit 0
fi

declare -a BAD_HOSTNAMES GOOD_HOSTNAMES BAD_AGENTS GOOD_AGENTS BAD_URLPATTERNS GOOD_URLPATTERNS
load_tokens_from_value "${BAD_HOSTNAMES:-}" BAD_HOSTNAMES
load_tokens_from_value "${GOOD_HOSTNAMES:-}" GOOD_HOSTNAMES
load_tokens_from_value "${BAD_AGENTS:-}" BAD_AGENTS
load_tokens_from_value "${GOOD_AGENTS:-}" GOOD_AGENTS
load_tokens_from_value "${BAD_URLPATTERNS:-}" BAD_URLPATTERNS
load_tokens_from_value "${GOOD_URLPATTERNS:-}" GOOD_URLPATTERNS

split_whitespace_values_preserving_quotes "$LOG_DIR" LOG_DIRS
(( ${#LOG_DIRS[@]} > 0 )) || { echo "LOG_DIR must contain at least one directory." >&2; exit 1; }

declare -a ACCESS_LOG_PATHS
for dir in "${LOG_DIRS[@]}"; do
    dir_path="$(strip_wrapping_quotes "$dir")"
    path="$dir_path/$ACCESS_LOG_BASENAME"
    [[ -f "$path" ]] && ACCESS_LOG_PATHS+=( "$path" )
done
(( ${#ACCESS_LOG_PATHS[@]} > 0 )) || { echo "Access log not found in configured LOG_DIR directories." >&2; exit 1; }

exec 9>"$LOCK_FILE"
flock -n 9 || { echo "Another realtime scan is currently running; exiting."; exit 0; }

now_epoch="$(date +%s)"
end_epoch=$((now_epoch - 60))
start_epoch=$((end_epoch - 120))

if [[ -f "$STATE_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$STATE_FILE" || true
    if [[ "${LAST_END_EPOCH:-}" =~ ^[0-9]+$ ]]; then
        cand_start="$LAST_END_EPOCH"
        cand_end=$((cand_start + 120))
        if (( cand_end <= end_epoch )); then
            start_epoch="$cand_start"
            end_epoch="$cand_end"
        fi
    fi
fi
(( end_epoch > start_epoch )) || { echo "No interval to process."; exit 0; }

hostname_cache_load "$HOSTNAME_CACHE_FILE"
declare -A ACTIONED_THIS_RUN

while IFS=$'\t' read -r ip path agent; do
    [[ -n "$ip" ]] || continue
    hostname="$(hostname_cache_get "$ip" "$DNS_TIMEOUT_SECONDS")"
    is_allowlisted_event "$ip" "$hostname" "$agent" GOOD_AGENTS GOOD_HOSTNAMES && continue

    ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    should_ban="off"

    if contains_any_token "$ip $hostname" "${BAD_HOSTNAMES[@]}"; then
        [[ "$HOST_SCAN_LOG" == "on" ]] && log_ban_event "$HOST_BAN_LOG" "$ts" "$ip" "$hostname" "$agent"
        [[ "$HOST_SCAN_BAN" == "on" ]] && should_ban="on"
    fi

    if contains_any_token "$agent" "${BAD_AGENTS[@]}"; then
        [[ "$AGENT_SCAN_LOG" == "on" ]] && {
            append_unique_line "$AGENT_UNIQUE_LOG" "$agent"
            log_ban_event "$AGENT_BAN_LOG" "$ts" "$ip" "$hostname" "$agent"
        }
        [[ "$AGENT_SCAN_BAN" == "on" ]] && should_ban="on"
    fi

    if urlpattern_path_matches "$path" "${BAD_URLPATTERNS[@]}" && \
       ! urlpattern_path_matches "$path" "${GOOD_URLPATTERNS[@]}"; then
        [[ "$URLPATTERN_SCAN_LOG" == "on" ]] && log_ban_event "$URLPATTERN_BAN_LOG" "$ts" "$ip" "$hostname" "$agent"
        [[ "$URLPATTERN_SCAN_BAN" == "on" ]] && should_ban="on"
    fi

    if [[ "$should_ban" == "on" && -z "${ACTIONED_THIS_RUN[$ip]+x}" ]] && ! is_ip_or_subnet_banned "$ip"; then
        ACTIONED_THIS_RUN[$ip]=1
        ban_ip32 "$ROOT_DIR" "$ip"
    fi
done < <(
    awk -v start="$start_epoch" -v end="$end_epoch" '
    function month_num(mon) {
        return (mon=="Jan")?1:(mon=="Feb")?2:(mon=="Mar")?3:(mon=="Apr")?4:(mon=="May")?5:(mon=="Jun")?6:(mon=="Jul")?7:(mon=="Aug")?8:(mon=="Sep")?9:(mon=="Oct")?10:(mon=="Nov")?11:12
    }
    {
        ip=$1; path="-"; ua="-"
        if (match($0, /\[([0-9]{2})\/([A-Za-z]{3})\/([0-9]{4}):([0-9]{2}):([0-9]{2}):([0-9]{2}) [+-][0-9]{4}\]/, m)) {
            epoch = mktime(m[3] " " month_num(m[2]) " " m[1] " " m[4] " " m[5] " " m[6])
        } else { next }
        if (epoch < start || epoch >= end) next
        if (match($0, /"[A-Z]+ ([^ ]+) HTTP\/[0-9.]+"/, req)) path=req[1]
        if (match($0, /"([^"]*)"$/, a)) ua=a[1]
        print ip "\t" path "\t" ua
    }' "${ACCESS_LOG_PATHS[@]}"
)

hostname_cache_save "$HOSTNAME_CACHE_FILE"
tmp_state="$(mktemp)"
printf 'LAST_END_EPOCH=%s\n' "$end_epoch" > "$tmp_state"
mv "$tmp_state" "$STATE_FILE"
