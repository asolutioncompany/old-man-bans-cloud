#!/bin/bash
# realtime-scan - Realtime access.log scanner.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/hostname-lookup-lib"
LOG_DIR_DEFAULT="/var/log/nginx"
ACCESS_LOG_BASENAME_DEFAULT="access.log"
DNS_TIMEOUT_SECONDS_DEFAULT=3
HOST_SCAN_LOG_DEFAULT="on"
HOST_SCAN_BAN_DEFAULT="on"

LOGS_DIR="$ROOT_DIR/logs"
mkdir -p "$LOGS_DIR"

STATE_FILE="$LOGS_DIR/realtime-scan.state"
LOCK_FILE="$LOGS_DIR/realtime-scan.lock"
REALTIME_HOST_BAN_LOG="$LOGS_DIR/realtime-host-ban-log"
HOSTNAME_CACHE_FILE="$LOGS_DIR/hostname-cache.tsv"

GLOBAL_CONFIG_FILE="$ROOT_DIR/config/old-man-bans-cloud.local"

if [[ -f "$GLOBAL_CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$GLOBAL_CONFIG_FILE"
fi

LOG_DIR="${LOG_DIR:-$LOG_DIR_DEFAULT}"
ACCESS_LOG_BASENAME="${ACCESS_LOG_BASENAME:-$ACCESS_LOG_BASENAME_DEFAULT}"
DNS_TIMEOUT_SECONDS="${DNS_TIMEOUT_SECONDS:-$DNS_TIMEOUT_SECONDS_DEFAULT}"
HOST_SCAN_LOG="${HOST_SCAN_LOG:-$HOST_SCAN_LOG_DEFAULT}"
HOST_SCAN_BAN="${HOST_SCAN_BAN:-$HOST_SCAN_BAN_DEFAULT}"

ACCESS_LOG_PATH="$LOG_DIR/$ACCESS_LOG_BASENAME"

if [[ ! -f "$ACCESS_LOG_PATH" ]]; then
    echo "Access log not found: $ACCESS_LOG_PATH" >&2
    exit 1
fi

if [[ ! "$HOST_SCAN_LOG" =~ ^(on|off)$ ]]; then
    echo "HOST_SCAN_LOG must be 'on' or 'off'." >&2
    exit 1
fi
if [[ ! "$HOST_SCAN_BAN" =~ ^(on|off)$ ]]; then
    echo "HOST_SCAN_BAN must be 'on' or 'off'." >&2
    exit 1
fi

to_lower() {
    echo "$1" | tr '[:upper:]' '[:lower:]'
}

load_tokens() {
    local file="$1"
    local -n out_ref="$2"
    out_ref=()
    [[ -f "$file" ]] || return 0

    local raw
    raw="$(tr -d '\n' < "$file")"
    raw="${raw// /}"
    IFS='|' read -r -a out_ref <<< "$raw"
}

contains_any_token() {
    local haystack
    haystack="$(to_lower "$1")"
    shift
    local token
    for token in "$@"; do
        [[ -z "$token" ]] && continue
        local token_lc
        token_lc="$(to_lower "$token")"
        if [[ "$haystack" == *"$token_lc"* ]]; then
            return 0
        fi
    done
    return 1
}

resolve_hostname() {
    local ip="$1"
    local host_out

    if host_out="$(timeout "${DNS_TIMEOUT_SECONDS}s" host "$ip" 2>/dev/null)"; then
        if [[ "$host_out" =~ pointer[[:space:]]+([^[:space:]]+)\.?$ ]]; then
            echo "${BASH_REMATCH[1]}"
            return 0
        fi
    else
        local rc=$?
        if [[ $rc -eq 124 ]]; then
            echo "-TIMEOUT-"
            return 0
        fi
    fi

    if host_out="$(timeout "${DNS_TIMEOUT_SECONDS}s" dig +short -x "$ip" 2>/dev/null)"; then
        local ptr
        ptr="$(echo "$host_out" | sed '/^[[:space:]]*$/d' | sed -n '1p' | sed 's/\.$//')"
        if [[ -n "$ptr" ]]; then
            echo "$ptr"
            return 0
        fi
    else
        local rc=$?
        if [[ $rc -eq 124 ]]; then
            echo "-TIMEOUT-"
            return 0
        fi
    fi

    echo "-"
}

log_host_event() {
    local timestamp="$1"
    local ip="$2"
    local hostname="$3"
    local agent="$4"
    printf '%s %s %s %s\n' "$timestamp" "$ip" "$hostname" "$agent" >> "$REALTIME_HOST_BAN_LOG"
}

ban_ip() {
    local ip="$1"
    "$ROOT_DIR/cli/perm-ban" "$ip/32" >/dev/null 2>&1 || true
}

declare -a BAD_CLOUDS GOOD_CLOUDS GOOD_AGENTS
load_tokens "$ROOT_DIR/config/bad-clouds.local" BAD_CLOUDS
load_tokens "$ROOT_DIR/config/good-clouds.local" GOOD_CLOUDS
load_tokens "$ROOT_DIR/config/good-agents.local" GOOD_AGENTS

if [[ "$HOST_SCAN_LOG" == "off" && "$HOST_SCAN_BAN" == "off" ]]; then
    echo "HOST_SCAN_LOG and HOST_SCAN_BAN are both off; exiting."
    exit 0
fi

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "Another realtime scan is currently running; exiting."
    exit 0
fi

now_epoch="$(date +%s)"
end_epoch=$((now_epoch - 60))
start_epoch=$((end_epoch - 120))

if [[ -f "$STATE_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$STATE_FILE" || true
    if [[ "${LAST_END_EPOCH:-}" =~ ^[0-9]+$ ]]; then
        candidate_start="$LAST_END_EPOCH"
        candidate_end=$((candidate_start + 120))
        if (( candidate_end <= end_epoch )); then
            start_epoch="$candidate_start"
            end_epoch="$candidate_end"
        fi
    fi
fi

if (( end_epoch <= start_epoch )); then
    echo "No interval to process."
    exit 0
fi

declare -A ACTIONED_THIS_RUN
hostname_cache_load "$HOSTNAME_CACHE_FILE"

while IFS=$'\t' read -r ip agent; do
    [[ -z "$ip" ]] && continue
    timestamp="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    hostname="-"
    hostname="$(hostname_cache_get "$ip" "$DNS_TIMEOUT_SECONDS")"

    # Global allowlists apply to both detection paths.
    if contains_any_token "$agent" "${GOOD_AGENTS[@]}" || \
       contains_any_token "$hostname" "${GOOD_AGENTS[@]}" || \
       contains_any_token "$ip $hostname" "${GOOD_CLOUDS[@]}"; then
        continue
    fi

    if contains_any_token "$ip $hostname" "${BAD_CLOUDS[@]}" && [[ -z "${ACTIONED_THIS_RUN[$ip]+x}" ]]; then
        if ipset test badnets_perm "$ip" >/dev/null 2>&1; then
            continue
        fi
        ACTIONED_THIS_RUN[$ip]=1
        if [[ "$HOST_SCAN_BAN" == "on" ]]; then
            ban_ip "$ip"
        fi
        if [[ "$HOST_SCAN_LOG" == "on" ]]; then
            log_host_event "$timestamp" "$ip" "$hostname" "$agent"
        fi
    fi
done < <(
    awk -v start="$start_epoch" -v end="$end_epoch" '
    function month_num(mon) {
        return (mon=="Jan")?1:(mon=="Feb")?2:(mon=="Mar")?3:(mon=="Apr")?4:(mon=="May")?5:(mon=="Jun")?6:(mon=="Jul")?7:(mon=="Aug")?8:(mon=="Sep")?9:(mon=="Oct")?10:(mon=="Nov")?11:12
    }
    {
        ip=$1
        ts=""
        ua=""

        if (match($0, /\[([0-9]{2})\/([A-Za-z]{3})\/([0-9]{4}):([0-9]{2}):([0-9]{2}):([0-9]{2}) [+-][0-9]{4}\]/, m)) {
            epoch = mktime(m[3] " " month_num(m[2]) " " m[1] " " m[4] " " m[5] " " m[6])
        } else {
            next
        }

        if (epoch < start || epoch >= end) {
            next
        }

        if (match($0, /"([^"]*)"$/, a)) {
            ua=a[1]
        } else {
            ua="-"
        }

        print ip "\t" ua
    }' "$ACCESS_LOG_PATH"
)

hostname_cache_save "$HOSTNAME_CACHE_FILE"

tmp_state="$(mktemp)"
printf 'LAST_END_EPOCH=%s\n' "$end_epoch" > "$tmp_state"
mv "$tmp_state" "$STATE_FILE"
