#!/bin/bash
# weekly-scan - Weekly (6 days) subnet promotion scanner.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/subnet-promote-lib"
# shellcheck disable=SC1091
source "$ROOT_DIR/lib/hostname-lookup-lib"

LOG_DIR_DEFAULT="/var/log/nginx"
ACCESS_LOG_BASENAME_DEFAULT="access.log"
DNS_TIMEOUT_SECONDS_DEFAULT=3
SITEMAP_SCAN_LOG_DEFAULT="on"
SITEMAP_SCAN_BAN_DEFAULT="on"
SUBNET_SCAN_LOG_DEFAULT="on"
SUBNET_SCAN_BAN_DEFAULT="on"
SUBNET_THRESHOLD_DEFAULT=10

LOGS_DIR="$ROOT_DIR/logs"
mkdir -p "$LOGS_DIR"

LOCK_FILE="$LOGS_DIR/weekly-scan.lock"
WEEKLY_EVENT_LOG="$LOGS_DIR/weekly-subnet-ban-log"
SUBNET_PROMOTION_LOG="$LOGS_DIR/subnet-promotion-log"
HOSTNAME_CACHE_FILE="$LOGS_DIR/hostname-cache.tsv"

GLOBAL_CONFIG_FILE="$ROOT_DIR/config/old-man-bans-cloud.local"
if [[ -f "$GLOBAL_CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$GLOBAL_CONFIG_FILE"
fi

LOG_DIR="${LOG_DIR:-$LOG_DIR_DEFAULT}"
ACCESS_LOG_BASENAME="${ACCESS_LOG_BASENAME:-$ACCESS_LOG_BASENAME_DEFAULT}"
DNS_TIMEOUT_SECONDS="${DNS_TIMEOUT_SECONDS:-$DNS_TIMEOUT_SECONDS_DEFAULT}"
SITEMAP_SCAN_LOG="${SITEMAP_SCAN_LOG:-$SITEMAP_SCAN_LOG_DEFAULT}"
SITEMAP_SCAN_BAN="${SITEMAP_SCAN_BAN:-$SITEMAP_SCAN_BAN_DEFAULT}"
SUBNET_SCAN_LOG="${SUBNET_SCAN_LOG:-$SUBNET_SCAN_LOG_DEFAULT}"
SUBNET_SCAN_BAN="${SUBNET_SCAN_BAN:-$SUBNET_SCAN_BAN_DEFAULT}"
SUBNET_THRESHOLD="${SUBNET_THRESHOLD:-$SUBNET_THRESHOLD_DEFAULT}"

if [[ ! "$SITEMAP_SCAN_LOG" =~ ^(on|off)$ ]]; then
    echo "SITEMAP_SCAN_LOG must be 'on' or 'off'." >&2
    exit 1
fi
if [[ ! "$SITEMAP_SCAN_BAN" =~ ^(on|off)$ ]]; then
    echo "SITEMAP_SCAN_BAN must be 'on' or 'off'." >&2
    exit 1
fi
if [[ ! "$SUBNET_SCAN_LOG" =~ ^(on|off)$ ]]; then
    echo "SUBNET_SCAN_LOG must be 'on' or 'off'." >&2
    exit 1
fi
if [[ ! "$SUBNET_SCAN_BAN" =~ ^(on|off)$ ]]; then
    echo "SUBNET_SCAN_BAN must be 'on' or 'off'." >&2
    exit 1
fi
if [[ ! "$SUBNET_THRESHOLD" =~ ^[0-9]+$ ]]; then
    echo "SUBNET_THRESHOLD must be an integer." >&2
    exit 1
fi
if [[ "$SITEMAP_SCAN_LOG" == "off" && "$SITEMAP_SCAN_BAN" == "off" && "$SUBNET_SCAN_LOG" == "off" && "$SUBNET_SCAN_BAN" == "off" ]]; then
    echo "All weekly sitemap/subnet LOG/BAN settings are off; exiting."
    exit 0
fi

to_lower() {
    echo "$1" | tr '[:upper:]' '[:lower:]'
}

load_tokens() {
    local file="$1"
    local -n out_ref="$2"
    out_ref=()
    [[ -f "$file" ]] || return 0

    local raw
    raw="$(tr -d '\n' < "$file")"
    raw="${raw// /}"
    IFS='|' read -r -a out_ref <<< "$raw"
}

contains_any_token() {
    local haystack
    haystack="$(to_lower "$1")"
    shift
    local token
    for token in "$@"; do
        [[ -z "$token" ]] && continue
        local token_lc
        token_lc="$(to_lower "$token")"
        if [[ "$haystack" == *"$token_lc"* ]]; then
            return 0
        fi
    done
    return 1
}

resolve_hostname() {
    local ip="$1"
    local host_out

    if host_out="$(timeout "${DNS_TIMEOUT_SECONDS}s" host "$ip" 2>/dev/null)"; then
        if [[ "$host_out" =~ pointer[[:space:]]+([^[:space:]]+)\.?$ ]]; then
            echo "${BASH_REMATCH[1]}"
            return 0
        fi
    else
        local rc=$?
        if [[ $rc -eq 124 ]]; then
            echo "-TIMEOUT-"
            return 0
        fi
    fi

    if host_out="$(timeout "${DNS_TIMEOUT_SECONDS}s" dig +short -x "$ip" 2>/dev/null)"; then
        local ptr
        ptr="$(echo "$host_out" | sed '/^[[:space:]]*$/d' | sed -n '1p' | sed 's/\.$//')"
        if [[ -n "$ptr" ]]; then
            echo "$ptr"
            return 0
        fi
    else
        local rc=$?
        if [[ $rc -eq 124 ]]; then
            echo "-TIMEOUT-"
            return 0
        fi
    fi

    echo "-"
}

log_event() {
    local ts="$1"
    local ip="$2"
    local hostname="$3"
    local agent="$4"
    printf '%s %s %s %s\n' "$ts" "$ip" "$hostname" "$agent" >> "$WEEKLY_EVENT_LOG"
}

declare -a SITEMAP_TOKENS GOOD_AGENTS GOOD_CLOUDS
load_tokens "$ROOT_DIR/config/sitemap.local" SITEMAP_TOKENS
load_tokens "$ROOT_DIR/config/good-agents.local" GOOD_AGENTS
load_tokens "$ROOT_DIR/config/good-clouds.local" GOOD_CLOUDS

if [[ ${#SITEMAP_TOKENS[@]} -eq 0 ]]; then
    echo "No sitemap tokens configured in config/sitemap.local; exiting."
    exit 0
fi

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "Another weekly scan is currently running; exiting."
    exit 0
fi

shopt -s nullglob
log_files=( "$LOG_DIR/$ACCESS_LOG_BASENAME".[1-9]* "$LOG_DIR/$ACCESS_LOG_BASENAME".[1-9]*.gz )
shopt -u nullglob

if [[ ${#log_files[@]} -eq 0 ]]; then
    echo "No rotated logs found for weekly scan."
    exit 0
fi

declare -A IP_AGENT IP_HOSTNAME IP_SUBNET SUBNET_COUNT
declare -A SUBNET_IPS
hostname_cache_load "$HOSTNAME_CACHE_FILE"

while IFS=$'\t' read -r ip path agent; do
    [[ -z "$ip" ]] && continue
    contains_any_token "$path" "${SITEMAP_TOKENS[@]}" || continue

    local_host="-"
    if [[ -z "${IP_HOSTNAME[$ip]+x}" ]]; then
        IP_HOSTNAME[$ip]="$(hostname_cache_get "$ip" "$DNS_TIMEOUT_SECONDS")"
    fi
    local_host="${IP_HOSTNAME[$ip]}"

    if contains_any_token "$agent" "${GOOD_AGENTS[@]}" || \
       contains_any_token "$local_host" "${GOOD_AGENTS[@]}" || \
       contains_any_token "$ip $local_host" "${GOOD_CLOUDS[@]}"; then
        continue
    fi

    if [[ -z "${IP_AGENT[$ip]+x}" ]]; then
        IP_AGENT[$ip]="$agent"
    fi

    if [[ -z "${IP_SUBNET[$ip]+x}" ]]; then
        subnet="$(ipv4_to_subnet24 "$ip" || true)"
        [[ -z "$subnet" ]] && continue
        IP_SUBNET[$ip]="$subnet"

        SUBNET_COUNT[$subnet]=$(( ${SUBNET_COUNT[$subnet]:-0} + 1 ))
        SUBNET_IPS[$subnet]="${SUBNET_IPS[$subnet]:-} $ip"
    fi
done < <(
    for f in "${log_files[@]}"; do
        if [[ "$f" == *.gz ]]; then
            gzip -cd "$f" || true
        else
            sed -n '1,$ p' "$f"
        fi
    done | awk '
    {
        ip=$1
        path="-"
        ua="-"

        if (match($0, /"[A-Z]+ ([^ ]+) HTTP\/[0-9.]+"/, req)) {
            path=req[1]
        }
        if (match($0, /"([^"]*)"$/, a)) {
            ua=a[1]
        }
        print ip "\t" path "\t" ua
    }'
)

for subnet in "${!SUBNET_COUNT[@]}"; do
    count="${SUBNET_COUNT[$subnet]}"
    if (( count <= SUBNET_THRESHOLD )); then
        continue
    fi

    if [[ "$SITEMAP_SCAN_BAN" == "on" && "$SUBNET_SCAN_BAN" == "on" ]]; then
        if ipset test badnets_perm "$subnet" >/dev/null 2>&1; then
            continue
        fi
        "$ROOT_DIR/cli/perm-ban" "$subnet" >/dev/null 2>&1 || true
        removed_count="$(remove_covered_ip32_bans "$ROOT_DIR" "$subnet")"
    else
        removed_count=0
    fi

    if [[ "$SUBNET_SCAN_LOG" == "on" ]]; then
        ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
        printf '%s subnet=%s unique_ips=%s removed_ip32=%s\n' \
            "$ts" "$subnet" "$count" "$removed_count" >> "$SUBNET_PROMOTION_LOG"
    fi
    if [[ "$SITEMAP_SCAN_LOG" == "on" ]]; then
        ts="${ts:-$(date -u +"%Y-%m-%dT%H:%M:%SZ")}"
        for ip in ${SUBNET_IPS[$subnet]}; do
            log_event "$ts" "$ip" "${IP_HOSTNAME[$ip]:--}" "${IP_AGENT[$ip]:--}"
        done
    fi
done

hostname_cache_save "$HOSTNAME_CACHE_FILE"
